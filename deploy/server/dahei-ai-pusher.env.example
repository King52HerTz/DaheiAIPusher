# 复制到 /etc/dahei-ai-pusher.env 后再填写。
# AppToken 属于应用密钥，不要提交真实值，也不要截图发到 Issue。
WXPUSHER_APP_TOKEN='AT_xxx'
WXPUSHER_UID=''
WXPUSHER_TOPIC_IDS='123456'

CONTENT_MODE='full'
RSS_URL='https://news.daheiai.com/rss.php'
STATE_FILE='/var/lib/dahei-ai-pusher/state.json'
MAX_CATCHUP_ITEMS='6'
HTTP_CONNECT_TIMEOUT='10'
HTTP_READ_TIMEOUT='20'
